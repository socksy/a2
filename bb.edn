{:paths ["src"]
 :min-bb-version "1.0.0"
 :deps {com.lambdaisland/launchpad {:mvn/version "0.46.204-alpha"}
        hiccup/hiccup {:mvn/version "2.0.0-RC3"}
        metosin/malli {:mvn/version "0.17.0"}
        io.github.socksy/ifu {:git/url "https://github.com/socksy/ifu.git"
                              :git/tag "v0.3.0"
                              :git/sha "cd7ef96"}}
 :tasks
 {generate {:doc "Generate interactive HTML: EDN → D2 → HTML"
            :requires ([a2.core :as core])
            :task (try (apply core/-main *command-line-args*)
                       (catch Exception e
                         (binding [*out* *err*] (println (ex-message e)))
                         (System/exit 1)))}
  dev {:doc "Start Launchpad REPL"
       :task (do (require '[lambdaisland.launchpad :as lp])
                 (lp/main {}))}
  tag {:doc "Git tag with version from VERSION file"
       :task (let [v (str "v" (clojure.string/trim (slurp (clojure.java.io/resource "VERSION"))))]
               (shell "git" "tag" v)
               (println (str "Tagged " v)))}
  mcp {:doc "Start bb-clj MCP server on port 8787"
       :task (babashka.tasks/shell {:dir (str (System/getProperty "user.home") "/code/mcp-bb-clj")}
                                   "bb" "-m" "mcp-bb-clj.core" "8787")}}}
